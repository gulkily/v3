# Production environment example

FORUM_REPOSITORY_ROOT=/srv/forum-rewrite/repository
FORUM_DATABASE_PATH=/srv/forum-rewrite/state/cache/post_index.sqlite3
FORUM_PUBLIC_ARTIFACT_ROOT=/srv/forum-rewrite/app/public

# Optional alternate static root for non-sibling artifact layouts.
# FORUM_STATIC_HTML_ROOT=/srv/forum-rewrite/state/static_html

# Optional: allow visible UTF-8 prose in authored post subject/body. Defaults to disabled.
# FORUM_UNICODE_AUTHORED_TEXT=false

# Optional: show browser-side app version polling and reload banner. Defaults to enabled.
# FORUM_APP_VERSION_NOTIFICATION=true

# Optional private config file for shared-hosting secrets.
# FORUM_SECRETS_PATH=/srv/forum-rewrite-private/secrets.php

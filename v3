#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMMAND="${1:-}"

if [[ -z "${COMMAND}" ]]; then
  cat <<'EOF'
Usage:
  ./v3 start [host:port]
  ./v3 test
  ./v3 rebuild [repository_root] [database_path]
  ./v3 thread-attributes <thread_id_or_record> [repository_root] [database_path]
  ./v3 delete-record <record_path_or_id> [repository_root] [database_path] [artifact_root]
  ./v3 unicode-risk-backfill [repository_root] [database_path] [--with-llm]
  ./v3 build-static [repository_root] [database_path] [artifact_root]
  ./v3 archive-thread <thread_id> [repository_root] [database_path] [artifact_root] [archive_path]
  ./v3 private-config [--force] [--api-key-stdin] [--path=/private/path/secrets.php]
  ./v3 approval seed <identity_id> [seed_reason] [repository_root] [database_path]
  ./v3 approval approve <approver_identity_id> <target_identity_id> [repository_root] [database_path] [artifact_root]
EOF
  exit 1
fi

case "${COMMAND}" in
  start)
    shift
    ADDRESS="${1:-127.0.0.1:8000}"
    php -S "${ADDRESS}" -t "${ROOT}/public" "${ROOT}/public/router.php"
    ;;
  test)
    shift
    php "${ROOT}/tests/run.php" "$@"
    ;;
  rebuild)
    shift
    php "${ROOT}/scripts/rebuild_read_model.php" "$@"
    ;;
  thread-attributes)
    shift
    php "${ROOT}/scripts/thread_attributes.php" "$@"
    ;;
  delete-record)
    shift
    php "${ROOT}/scripts/delete_record.php" "$@"
    ;;
  unicode-risk-backfill)
    shift
    php "${ROOT}/scripts/backfill_unicode_risk.php" "$@"
    ;;
  build-static)
    shift
    php "${ROOT}/scripts/build_static_artifacts.php" "$@"
    ;;
  archive-thread)
    shift
    php "${ROOT}/scripts/archive_thread.php" "$@"
    ;;
  private-config)
    shift
    php "${ROOT}/scripts/write_private_config.php" "$@"
    ;;
  approval)
    shift
    php "${ROOT}/scripts/inject_approval.php" "$@"
    ;;
  *)
    echo "Unknown command: ${COMMAND}" >&2
    echo "Run ./v3 with no arguments to see available commands." >&2
    exit 1
    ;;
esac
